{
  "name": "dsp-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "api:lint": "redocly lint openapi.yaml --config redocly.yaml",
    "api:preview": "redocly preview-docs openapi.yaml --config redocly.yaml"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.0.0",
    "bullmq": "^5.0.0",
    "dotenv": "^17.4.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.0.0",
    "yaml": "^2.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@redocly/cli": "^1.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
