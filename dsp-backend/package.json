{
  "name": "dsp-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "api:types": "openapi-typescript openapi.yaml -o src/core/types/openapi.generated.ts",
    "api:lint": "redocly lint openapi.yaml --config redocly.yaml",
    "api:preview": "redocly preview-docs openapi.yaml --config redocly.yaml"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.0.0",
    "dotenv": "^17.4.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.0.0",
    "yaml": "^2.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@redocly/cli": "^1.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "openapi-typescript": "^7.13.0",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
